# ============================================================
# Email Warm-Up Platform — environment template
# Copy to .env.local for local development. On Vercel, add these
# under Project → Settings → Environment Variables.
#
# ALL of these are server-side secrets. There are intentionally
# NO NEXT_PUBLIC_ variables — the browser never talks to Supabase.
# ============================================================

# Supabase cloud project (Dashboard → Project Settings → API)
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# Service role key — SERVER ONLY, bypasses RLS. Never expose it.
# (Dashboard → Project Settings → API Keys → service_role)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Key used to AES-256-GCM encrypt stored SMTP/IMAP passwords.
# Generate: openssl rand -hex 32   (or any 32+ char random string)
# Changing it later makes previously saved passwords unreadable.
ENCRYPTION_KEY=change-me-to-a-long-random-string

# Shared secret protecting /api/cron/tick.
# Generate: openssl rand -hex 32
# Must match the value used in supabase/setup-cron.sql.
CRON_SECRET=change-me-to-another-long-random-string

# Optional — AI-generated emails via Groq (https://console.groq.com).
# Without it, the built-in randomized template library is used.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
